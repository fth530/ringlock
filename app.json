{
  "expo": {
    "name": "RingLock",
    "slug": "ringlock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ringlock",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.corut.ringlock",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This permission is used to show you relevant ads."
        }
      ],
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-3876117181338566~4445272034"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "14308d5c-c022-4cae-91a9-146bcd322cc8"
      }
    }
  }
}
